generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String              @id @db.VarChar(30)
  name               String              @db.VarChar(100)
  email              String              @unique @db.VarChar(255)
  passwordHash       String
  regiment           String              @db.VarChar(100)
  phone              String?             @db.VarChar(20)
  role               Role                @default(USER)
  status             UserStatus          @default(PENDING)
  emailVerified      Boolean             @default(false)
  emailVerifiedAt    DateTime?           @db.Timestamp(6)
  loginAttempts      Int                 @default(0)
  lockedUntil        DateTime?           @db.Timestamp(6)
  lastLoginAt        DateTime?           @db.Timestamp(6)
  createdAt          DateTime            @default(now()) @db.Timestamp(6)
  updatedAt          DateTime            @default(now()) @updatedAt @db.Timestamp(6)
  bookings           Booking[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  sessions           Session[]

  @@index([email], map: "idx_users_email")
  @@index([status], map: "idx_users_status")
  @@map("users")
}

model Slot {
  id        String    @id @db.VarChar(30)
  date      DateTime  @db.Date
  time      String    @db.VarChar(20)
  capacity  Int       @default(20)
  booked    Int       @default(0)
  disabled  Boolean   @default(false)
  holiday   Boolean   @default(false)
  createdAt DateTime  @default(now()) @db.Timestamp(6)
  updatedAt DateTime  @default(now()) @updatedAt @db.Timestamp(6)
  bookings  Booking[]

  @@unique([date, time])
  @@index([date], map: "idx_slots_date")
  @@map("slots")
}

model Booking {
  id           String        @id @db.VarChar(30)
  tokenNo      String        @unique @db.VarChar(20)
  userId       String        @db.VarChar(30)
  slotId       String        @db.VarChar(30)
  category     Category
  status       BookingStatus @default(ACTIVE)
  cancelledBy  String?       @db.VarChar(30)
  cancelReason String?
  createdAt    DateTime      @default(now()) @db.Timestamp(6)
  updatedAt    DateTime      @default(now()) @updatedAt @db.Timestamp(6)
  slot         Slot          @relation(fields: [slotId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, slotId])
  @@index([slotId], map: "idx_bookings_slotid")
  @@index([status], map: "idx_bookings_status")
  @@index([userId], map: "idx_bookings_userid")
  @@map("bookings")
}

model Session {
  id           String   @id @db.VarChar(30)
  userId       String   @db.VarChar(30)
  refreshToken String   @unique @db.VarChar(100)
  ipAddress    String?  @db.VarChar(50)
  userAgent    String?
  expiresAt    DateTime @db.Timestamp(6)
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([refreshToken], map: "idx_sessions_refreshtoken")
  @@index([userId], map: "idx_sessions_userid")
  @@map("sessions")
}

model PasswordReset {
  id        String   @id @db.VarChar(30)
  userId    String   @db.VarChar(30)
  token     String   @unique @db.VarChar(100)
  expiresAt DateTime @db.Timestamp(6)
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token], map: "idx_password_resets_token")
  @@map("password_resets")
}

model EmailVerification {
  id        String   @id @db.VarChar(30)
  userId    String   @db.VarChar(30)
  token     String   @unique @db.VarChar(100)
  expiresAt DateTime @db.Timestamp(6)
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token], map: "idx_email_verifications_token")
  @@map("email_verifications")
}

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
  SUSPENDED
}

enum Category {
  GROCERY
  LIQUOR_ONLY
  GROCERY_AND_LIQUOR
}

enum BookingStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}
